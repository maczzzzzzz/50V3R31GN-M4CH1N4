{
  "editor.fontFamily": "'VT323', 'JetBrains Mono', 'Hack', 'Fira Code', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.lineHeight": 22,

  "markdown.preview.fontFamily": "'VT323', monospace",
  "markdown.preview.fontSize": 18,

  "workbench.colorTheme": "Dark 2026",
  "workbench.colorCustomizations": {
    "[Gruvbox Dark Soft]": {
      "activityBar.background":             "#1d2021",
      "activityBar.foreground":             "#ebdbb2",
      "sideBar.background":                 "#1d2021",
      "sideBar.foreground":                 "#ebdbb2",
      "editor.background":                  "#282828",
      "editor.foreground":                  "#ebdbb2",
      "statusBar.background":               "#282828",
      "statusBar.foreground":               "#ebdbb2",
      "titleBar.activeBackground":          "#1d2021",
      "tab.activeBackground":               "#3c3836",
      "terminal.background":                "#282828"
    },
    "focusBorder":                        "#fabd2f",
    "editorCursor.foreground":            "#ebdbb2"
  },

  "editor.tokenColorCustomizations": {
    "comments":   "#928374",
    "keywords":   "#fb4934",
    "strings":    "#b8bb26",
    "functions":  "#8ec07c",
    "numbers":    "#d3869b",
    "types":      "#fabd2f"
  }
}
