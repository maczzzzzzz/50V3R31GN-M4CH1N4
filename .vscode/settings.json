  "editor.tokenColorCustomizations": {
    "comments":   "#440000",
    "keywords":   "#ff1a1a",
    "strings":    "#cc4444",
    "functions":  "#ff6666",
    "numbers":    "#ff8888",
    "types":      "#ff4444"
  }
