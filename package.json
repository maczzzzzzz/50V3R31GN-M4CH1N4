  "scripts": {
    "start": "echo '[DECOMMISSIONED] hermes-core shadow logic removed — use: npm run terminal'",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "f(){ if [ -z \"$IN_NIX_SHELL\" ] && command -v nix >/dev/null 2>&1; then nix develop .#default --command vitest run \"$@\"; else vitest run \"$@\"; fi; }; f",
    "test:live": "npx concurrently \"bash scripts/watch-logs.sh\" \"/mnt/c/Windows/System32/cmd.exe /c 'cd C:\\Temp\\foundry-auto && node test.js'\"",
    "test:watch": "f(){ if [ -z \"$IN_NIX_SHELL\" ] && command -v nix >/dev/null 2>&1; then nix develop .#default --command vitest \"$@\"; else vitest \"$@\"; fi; }; f",
    "audit:theme": "tsx scripts/theme-auditor.ts",
    "audit:theme:dry": "tsx scripts/theme-auditor.ts --dry-run",
    "boot": "./deck-igniter-cli start",
    "boot:cpr": "IGNITER_MODE=cpr ./deck-igniter-cli start",
    "boot:ghost": "./deck-igniter-cli ghost",
    "boot:headless": "HEADLESS=1 ./deck-igniter-cli start",
    "hub": "nix develop --impure --command ./crates/sidecar-cyberdeck/target/release/sidecar-cyberdeck",
    "hub:headless": "nix develop --impure --command ./crates/sidecar-cyberdeck/target/release/sidecar-cyberdeck --headless",
    "atlas": "nix develop --impure --command ./crates/sidecar-atlas/target/release/sidecar-atlas",
    "atlas:headless": "nix develop --impure --command ./crates/sidecar-atlas/target/release/sidecar-atlas --headless",
    "netrunning": "nix develop --impure --command ./crates/sidecar-netrunning/target/release/sidecar-netrunning",
    "netrunning:headless": "nix develop --impure --command ./crates/sidecar-netrunning/target/release/sidecar-netrunning --headless",
    "terminal": "cd sidecars/hermes-agent-nous && nix develop --impure --command python3 -m hermes_cli.main chat --tui",
    "dashboard:hermes": "cd sidecars/hermes-agent-nous && nix develop --impure --command python3 -m hermes_cli.main dashboard --port 9119 --host 0.0.0.0 --insecure --tui",
    "ink:terminal": "cd sidecars/hermes-agent-nous && nix develop --impure --command python3 -m hermes_cli.main chat --tui",
    "pulse": "npx tsx scripts/dev/sovereign-pulse.ts",
    "build:sidecar:atlas": "nix develop --impure --command cargo build --release --manifest-path crates/sidecar-atlas/Cargo.toml",
    "build:sidecar:cyberdeck": "nix develop --impure --command cargo build --release --manifest-path crates/sidecar-cyberdeck/Cargo.toml",
    "build:sidecar:netrunning": "nix develop --impure --command cargo build --release --manifest-path crates/sidecar-netrunning/Cargo.toml",
    "build:sidecar:kernel": "nix develop --impure --command cargo build --release --manifest-path crates/sovereign-kernel/Cargo.toml",
    "kernel": "nix develop --impure --command ./crates/sovereign-kernel/target/release/sovereign-kernel",
    "build:sidecars": "npm run build:sidecar:atlas && npm run build:sidecar:cyberdeck && npm run build:sidecar:netrunning && npm run build:sidecar:kernel",
    "harmonize": "tsx scripts/harmonize-rkg.ts",
    "harmonize:dry": "tsx scripts/harmonize-rkg.ts --dry-run",
    "reconstruct": "python3 scripts/fast-reconstruct.py",
    "crush": "./crush-cli",
    "crush:nucleus": "./crush-cli nucleus",
    "dream": "echo '[DECOMMISSIONED] dream-daemon migrated to python shard'",
    "dream:once": "echo '[DECOMMISSIONED] dream:once migrated to python shard'",
    "mcp:start": "tsx scripts/dev/mcp-daemon.ts",
    "mcp:test": "tsx scripts/dev/test-mcp-connection.ts",
    "gauntlet": "tsx scripts/gauntlet/engine.ts",
    "gauntlet:no-cdp": "tsx scripts/gauntlet/engine.ts --no-cdp",
    "gauntlet:manifest": "tsx scripts/gauntlet/engine.ts --manifest",
    "director:ignite": "tsx scripts/ops/ignite-director.ts",
    "synapse:ignite": "nix develop .#cuda --command go run scripts/ops/mooncake-master.go --config config/mooncake_master.json",
    "forge:skills": "tsx scripts/forge/skill-factory.ts --once",
    "forge:skills:watch": "tsx scripts/forge/skill-factory.ts",
    "forge:topology": "tsx scripts/forge/topology-lib/generate-pngs.ts",
    "forge:blueprint": "tsx scripts/forge/blueprint-engine.ts",
    "forge:gepa": "tsx scripts/forge/gepa-optimizer.ts",
    "forge:gepa:dry": "tsx scripts/forge/gepa-optimizer.ts --dry-run",
    "forge:threats": "tsx scripts/forge/export-threat-library.ts",
    "forge:threats:akashik": "tsx scripts/forge/export-threat-library.ts --source=akashik",
    "forge:threats:foundry": "tsx scripts/forge/export-threat-library.ts --source=foundry",
    "forge:atlas": "tsx scripts/forge/atlas-forge.ts",
    "forge:assembler": "tsx scripts/forge/assembler.ts",
    "forge:master": "tsx scripts/forge/master-forge.ts",
    "audit:vitals": "tsx scripts/audit/vitals-heartbeat.ts",
    "audit:repos": "tsx scripts/audit/repo-update-scanner.ts",
    "scribe": "tsx scripts/ops/sdk-forge.ts && tsx scripts/audit/universal-synchronizer.ts && tsx scripts/ops/index-shards.ts",
    "sync": "npm run scribe",
    "node:sync": "bash scripts/ops/node-surgical-sync.sh",
    "scribe:lock": "npm run scribe && git add . && git commit -m 'chore: universal scribe sync' && git push origin master",
    "audit:components": "tsx -e \"import('./scripts/audit/component-auditor.js').then(m => m.auditAllComponents()).then(r => console.log(JSON.stringify(r, null, 2)))\"",
    "forge:backup": "tsx scripts/forge/backup-legacy-assets.ts",
    "forge:ingest": "tsx scripts/forge/ingest-local-assets.ts",
    "forge:tokens": "tsx scripts/forge/token-forge.ts",
    "forge:props": "tsx scripts/forge/prop-forge.ts",
    "mind:backup": "tsx scripts/recovery/backup-mind.ts",
    "mind:fresh": "tsx scripts/forge/fresh-db.ts",
    "mind:fresh:dry": "tsx scripts/forge/fresh-db.ts --dry-run",
    "mind:ingest": "echo '[DECOMMISSIONED] mind:ingest migrated to python shard'",
    "mind:materialize": "python3 scripts/fast-reconstruct.py"
