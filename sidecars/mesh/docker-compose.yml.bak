version: "3.9"

services:
  litellm:
    image: ghcr.io/berriai/litellm:main-latest
    container_name: mesh-litellm
    ports:
      - "4000:4000"
    volumes:
      - ./data:/app/data
      - ./litellm-mesh.yaml:/app/config.yaml:ro
    environment:
      - LITELLM_MASTER_KEY=${LITELLM_MASTER_KEY}
      - MESH_API_KEY=machina-internal-mesh-key-2026
      - LITELLM_LOG_LEVEL=INFO
    command: >
      --config /app/config.yaml
      --port 4000
      --host 0.0.0.0
    restart: unless-stopped
