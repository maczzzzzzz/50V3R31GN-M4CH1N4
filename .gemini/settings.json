{
  "model": "gemini-3-pro",
  "systemInstruction": "You are the Senior Systems Architect for 'asp-gm-agent'. Adhere to the 'No Creep' contract. Node A (.50) is Authority. Node B (.51) is Orchestrator.",
  "coreTools": ["google_web_search", "shell_execute", "file_read_write"],
  "mcpServers": {
    "nitro-db": {
      "command": "npx",
      "args": ["tsx", "src/mcp/db-server.ts"],
      "env": { "DB_HOST": "192.168.0.50" }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }
  },
  "agentMode": {
    "planFirst": true,
    "checkpointing": true
  }
}