# Node A (Rules Authority - Nitro 5)
NODE_A_HOST=192.168.0.50
CLAWLINK_PORT=7878
NODE_A_USER=maczz
BONSAI_MODEL=hf.co/prism-ml/Bonsai-8B-gguf

# Node B (Orchestrator - This Rig)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KV_CACHE_TYPE=fp8
OLLAMA_FLASH_ATTENTION=true

# Force Vulkan path to bypass ROCm discovery timeouts on RDNA 4 (RX 9060 XT)
OLLAMA_VULKAN=1
OLLAMA_LLM_LIBRARY=vulkan
GGML_VK_VISIBLE_DEVICES=0

# System-wide Settings
EMBEDDING_MODEL=nomic-embed-text
WORLD_DB_PATH=./world.db
CRUSH_DB_PATH=./.crush/crush.db

# Screamsheet Chronicler
DISCORD_WEBHOOK_URL=
