NODE_A_PASSWORD=
NODE_A_HOST=192.168.0.50
NODE_A_PORT=5432
NODE_A_DB=nitro_db
NODE_A_USER=nitro_admin

# Node B (Orchestrator) - AMD GPU Optimization (Windows)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KV_CACHE_TYPE=fp8
OLLAMA_FLASH_ATTENTION=true

# Force Vulkan path to bypass ROCm discovery timeouts on RDNA 4
OLLAMA_VULKAN=1
OLLAMA_LLM_LIBRARY=vulkan
GGML_VK_VISIBLE_DEVICES=0

# OLLAMA_LOAD_TIMEOUT=10m gives more time for GPU discovery if it times out
OLLAMA_LOAD_TIMEOUT=10m

EMBEDDING_MODEL=nomic-embed-text
NODE_A_LLAMA_URL=http://192.168.0.50:8080/v1
NODE_A_LLAMA_MODEL=local-llama
NODE_A_LLAMA_SEED=42
WORLD_DB_PATH=./world.db
CRUSH_DB_PATH=./.crush/crush.db
