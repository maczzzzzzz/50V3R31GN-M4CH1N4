{
  "name": "sidecar-obsidian-plugin",
  "version": "3.8.7",
  "description": "Sovereign Mesh Artery for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --external:obsidian --format=cjs --watch --outfile=main.js",
    "build": "esbuild src/main.ts --bundle --external:obsidian --format=cjs --minify --outfile=main.js"
  },
  "devDependencies": {
    "esbuild": "0.25.0",
    "obsidian": "latest",
    "typescript": "5.8.3"
  }
}
